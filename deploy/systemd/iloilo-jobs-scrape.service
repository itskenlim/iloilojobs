[Unit]
Description=Iloilo Jobs scrape and push job data
Documentation=https://github.com/itskenlim/iloilojobs
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=kenken
WorkingDirectory=/home/kenken/dev/personal/iloilojobs
Environment=ILOILO_JOBS_ROOT=/home/kenken/dev/personal/iloilojobs
ExecStart=/home/kenken/dev/personal/iloilojobs/scripts/scrape-and-push.sh
Nice=10
StandardOutput=journal
StandardError=journal
